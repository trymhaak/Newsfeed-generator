{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm install)",
      "Bash(npm run *)",
      "Bash(npx astro *)",
      "Bash(npx tsx *)",
      "Bash(git add *)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git commit *)",
      "Read(src/**)",
      "Read(scripts/**)",
      "Read(config/**)",
      "Read(data/**)",
      "Edit(src/**)",
      "Edit(scripts/**)",
      "Edit(config/**)",
      "Write(src/**)",
      "Write(scripts/**)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Read(.env)",
      "Read(.env.*)",
      "Bash(git push --force *)",
      "Bash(git push -f *)"
    ],
    "ask": [
      "Bash(git push *)",
      "Edit(.github/workflows/**)",
      "Write(.github/workflows/**)",
      "Edit(data/articles.json)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/session-start.sh",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
