---
import Newspaper from '../layouts/Newspaper.astro';
import HeroStory from '../components/HeroStory.astro';
import MidStory from '../components/MidStory.astro';
import LatestList from '../components/LatestList.astro';
import TopicBlock from '../components/TopicBlock.astro';
import { loadStore, selectFrontPage, articlesByTopic } from '../lib/store.ts';
import { TOPICS, type Topic } from '../lib/types.ts';

const store = await loadStore();
const { hero, mid, latest, byTopic } = selectFrontPage(store.articles);
const empty = store.articles.length === 0;

const topicCounts = Object.fromEntries(
  TOPICS.map((t) => [t, articlesByTopic(store.articles, t).length]),
) as Record<Topic, number>;
---
<Newspaper
  title="Nyhetsfeed — Microsoft-økosystemet"
  description="Automatisk-generert VG-style nyhetsoversikt for Intune, Entra, Defender, Copilot mfl."
  generated={store.generated}
  topicCounts={topicCounts}
>
  {empty
    ? (
      <div class="container">
        <div class="empty-state">
          <h2>Ingen saker enda</h2>
          <p>Pipelinen har ikke kjørt enda. Kjør <code>npm run pipeline</code> eller vent på neste cron-trigger.</p>
        </div>
      </div>
    )
    : (
      <>
        {hero && <HeroStory article={hero} />}

        {mid.length > 0 && (
          <section class="mid">
            <div class="container">
              <h2 class="section-title">Mer fra nyhetsfeeden</h2>
              <div class="mid-grid">
                {mid.map((a) => <MidStory article={a} />)}
              </div>
            </div>
          </section>
        )}

        {latest.length > 0 && <LatestList articles={latest} />}

        <section class="topics" style="padding: 0 0 8px;">
          <div class="container">
            <div class="topic-grid">
              {TOPICS.map((t) => <TopicBlock topic={t} articles={byTopic[t]} />)}
            </div>
          </div>
        </section>
      </>
    )}
</Newspaper>
