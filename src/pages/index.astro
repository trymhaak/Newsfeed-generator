---
const destination = 'https://trym.cloud/security/briefing/';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta http-equiv="refresh" content={`0;url=${destination}`} />
    <link rel="canonical" href={destination} />
    <title>Security Briefing has moved | Trym Cloud</title>
    <meta name="description" content="The Security Briefing is now part of Trym Cloud." />
    <style>
      :root { color-scheme: light dark; font-family: system-ui, sans-serif; }
      body { display: grid; min-height: 100vh; margin: 0; place-items: center; }
      main { max-width: 36rem; padding: 2rem; text-align: center; }
      a { font-weight: 700; }
    </style>
  </head>
  <body>
    <main>
      <h1>Security Briefing has moved</h1>
      <p>The newsfeed is now part of Trym Cloud.</p>
      <p><a href={destination}>Continue to the Trym Cloud Security Briefing</a></p>
    </main>
  </body>
</html>
