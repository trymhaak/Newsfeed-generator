---
import type { EnrichedArticle, Topic } from '../lib/types.ts';
import { TOPIC_LABELS } from '../lib/types.ts';

interface Props { topic: Topic; articles: EnrichedArticle[]; }
const { topic, articles } = Astro.props;
const base = (import.meta.env.BASE_URL || '/').replace(/\/$/, '');
---
<div class={`topic-block ${topic}`}>
  <header class="topic-block-header">
    <span class="dot" aria-hidden="true"></span>
    <h3><a href={`${base}/tema/${topic}`}>{TOPIC_LABELS[topic]}</a></h3>
  </header>
  {articles.length === 0
    ? <p class="none">Ingen saker enda</p>
    : (
      <ul>
        {articles.map((a) => (
          <li><a href={`${base}/artikkel/${a.id}`}>{a.headline_no}</a></li>
        ))}
      </ul>
    )}
</div>
