---
import type { EnrichedArticle, Topic } from '../lib/types.ts';
import { TOPIC_LABELS } from '../lib/types.ts';

interface Props {
  topic: Topic;
  articles: EnrichedArticle[];
}
const { topic, articles } = Astro.props;
const base = (import.meta.env.BASE_URL || '/').replace(/\/$/, '');
---
<div class={`topic-block ${topic}`}>
  <h3><a href={`${base}/tema/${topic}`} style="color: inherit;">{TOPIC_LABELS[topic]}</a></h3>
  {articles.length === 0
    ? <p style="color: var(--ink-mute); font-size: 14px;">Ingen saker enda</p>
    : (
      <ul>
        {articles.map((a) => (
          <li><a href={`${base}/artikkel/${a.id}`}>{a.headline_no}</a></li>
        ))}
      </ul>
    )}
</div>
