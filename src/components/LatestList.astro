---
import type { EnrichedArticle } from '../lib/types.ts';
import { TOPIC_LABELS } from '../lib/types.ts';

interface Props { articles: EnrichedArticle[]; }
const { articles } = Astro.props;
const base = (import.meta.env.BASE_URL || '/').replace(/\/$/, '');

function shortTime(iso: string): string {
  const m = Math.round((Date.now() - +new Date(iso)) / 60000);
  if (m < 60) return `${m}m`;
  const h = Math.round(m / 60);
  if (h < 24) return `${h}t`;
  const d = Math.round(h / 24);
  return `${d}d`;
}
---
<section class="latest">
  <div class="container">
    <h2 class="section-title">Siste nytt</h2>
    <ul class="latest-list">
      {articles.map((a) => (
        <li class="latest-item">
          <span class="time">{shortTime(a.published)}</span>
          <div class="body">
            <span class={`label ${a.topic}`}>{TOPIC_LABELS[a.topic]}</span>
            <h3><a href={`${base}/artikkel/${a.id}`}>{a.headline_no}</a></h3>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>
