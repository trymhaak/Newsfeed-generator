---
import type { EnrichedArticle } from '../lib/types.ts';
import { TOPIC_LABELS } from '../lib/types.ts';

interface Props { article: EnrichedArticle; }
const { article } = Astro.props;
const base = (import.meta.env.BASE_URL || '/').replace(/\/$/, '');
const href = `${base}/artikkel/${article.id}`;
const initial = article.headline_no.charAt(0).toUpperCase();

function relativeTime(iso: string): string {
  const m = Math.round((Date.now() - +new Date(iso)) / 60000);
  if (m < 60) return `${m} min siden`;
  const h = Math.round(m / 60);
  if (h < 24) return `${h} t siden`;
  const d = Math.round(h / 24);
  return `${d} d siden`;
}
---
<article class="mid-card">
  <a href={href} class="cover" aria-hidden="true" tabindex="-1">
    {article.hero_image
      ? <img src={article.hero_image} alt="" loading="lazy" width="640" height="360" />
      : <div class="placeholder">{initial}</div>}
  </a>
  <span class={`label ${article.topic}`}>{TOPIC_LABELS[article.topic]}</span>
  <h2><a href={href}>{article.headline_no}</a></h2>
  <p>{article.summary_no}</p>
  <p class="meta">{article.source_name} · {relativeTime(article.published)}</p>
</article>
