---
import type { EnrichedArticle } from '../lib/types.ts';
import TopicPill from './TopicPill.astro';

interface Props { article: EnrichedArticle; }
const { article } = Astro.props;
const base = (import.meta.env.BASE_URL || '/').replace(/\/$/, '');
const href = `${base}/artikkel/${article.id}`;
const initial = article.headline_no.charAt(0).toUpperCase();
---
<article class="hero">
  <a href={href} aria-label={article.headline_no}>
    {article.hero_image
      ? <img class="hero-image" src={article.hero_image} alt="" loading="eager" />
      : <div class="hero-image-placeholder" aria-hidden="true">{initial}</div>}
  </a>
  <div class="hero-body">
    <TopicPill topic={article.topic} />
    <h1><a href={href}>{article.headline_no}</a></h1>
    <p class="lede">{article.summary_no}</p>
    <p style="font-size: 13px; color: var(--ink-mute); margin: 0;">
      {article.source_name}
    </p>
  </div>
</article>
